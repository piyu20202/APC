# Podfile
# Modern Flutter Podfile structure for reliable CI builds
platform :ios, '12.0'

# Standard Flutter pod helper - this is normally generated by Flutter
# If it doesn't exist in the project, we'll use a standard path lookup if needed,
# but usually it's required like this.
begin
  require_relative File.join('..', 'Flutter', 'podhelper')
rescue LoadError
  # Fallback just in case during transition
  puts "Note: ios/Flutter/podhelper.rb not found, attempting to continue."
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Replaces manual 'pod' lines for all plugins and the Flutter engine
  if defined?(flutter_install_all_ios_pods)
    flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  else
    # Fallback to manual setup ONLY if podhelper is missing (should not happen with proper migration)
    pod 'Flutter', :path => 'Flutter'
    pod 'device_info_plus', :path => '.symlinks/plugins/device_info_plus/ios'
    pod 'syncfusion_flutter_pdfviewer', :path => '.symlinks/plugins/syncfusion_flutter_pdfviewer/ios'
    pod 'flutter_secure_storage', :path => '.symlinks/plugins/flutter_secure_storage/ios'
    pod 'shared_preferences_ios', :path => '.symlinks/plugins/shared_preferences_ios/ios'
    pod 'sqflite', :path => '.symlinks/plugins/sqflite/ios'
    pod 'url_launcher_ios', :path => '.symlinks/plugins/url_launcher_ios/ios'
    pod 'webview_flutter_wkwebview', :path => '.symlinks/plugins/webview_flutter_wkwebview/ios'
    pod 'google_sign_in_ios', :path => '.symlinks/plugins/google_sign_in_ios/ios'
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target) if defined?(flutter_additional_ios_build_settings)
    
    # Consistent deployment target 12.0
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '12.0'
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_CAMERA=1',
      ]
    end
  end
end
